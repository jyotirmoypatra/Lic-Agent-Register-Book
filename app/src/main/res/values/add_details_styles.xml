<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ModernFormField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/modern_form_field</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">10dp</item>
    </style>

    <style name="ModernFormField.Spaced">
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <style name="ModernFormIcon">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:tint">@color/search_accent</item>
    </style>

    <style name="ModernFormEditText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:padding">0dp</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">@color/search_primary_text</item>
        <item name="android:textColorHint">@color/search_hint_text</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="ModernClearIcon">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:padding">9dp</item>
    </style>

</resources>
