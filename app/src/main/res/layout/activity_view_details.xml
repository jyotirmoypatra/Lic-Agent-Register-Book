<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/search_screen_background"
    tools:context=".ViewDetailsActivity">

    <View
        android:id="@+id/detailsHeader"
        android:layout_width="0dp"
        android:layout_height="92dp"
        android:background="@drawable/search_header_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/detailsBackButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:padding="9dp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/detailsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp"
        android:text="@string/policy_holder_details"
        android:textColor="@color/white"
        android:textSize="21sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/detailsBackButton"
        app:layout_constraintEnd_toStartOf="@id/edit_Btn"
        app:layout_constraintStart_toEndOf="@id/detailsBackButton"
        app:layout_constraintTop_toTopOf="@id/detailsBackButton" />

    <ImageView
        android:id="@+id/edit_Btn"
        style="@style/ModernHeaderAction"
        android:contentDescription="@string/edit_details"
        android:src="@drawable/ic_edit"
        app:layout_constraintEnd_toStartOf="@id/delete_Btn"
        app:layout_constraintTop_toTopOf="@id/detailsBackButton" />

    <ImageView
        android:id="@+id/delete_Btn"
        style="@style/ModernHeaderAction"
        android:layout_marginEnd="12dp"
        android:contentDescription="@string/delete_details"
        android:src="@drawable/ic_delete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/detailsBackButton" />

    <ImageView
        android:id="@+id/save_btn"
        style="@style/ModernHeaderAction"
        android:contentDescription="@string/save_changes"
        android:src="@drawable/ic_done"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/delete_Btn"
        app:layout_constraintTop_toTopOf="@id/detailsBackButton" />

    <TextView
        android:id="@+id/detailsSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="24dp"
        android:text="@string/view_details_subtitle"
        android:textColor="@color/search_header_subtitle"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detailsBackButton" />

    <ScrollView
        android:id="@+id/scroolDetails"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detailsHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="28dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/topBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/search_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/policy_avatar_background"
                        android:contentDescription="@null"
                        android:padding="14dp"
                        android:src="@drawable/ic_account"
                        app:tint="@color/search_accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/policy_holder"
                            android:textColor="@color/search_secondary_text"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/viewName"
                            style="@style/ModernDetailName"
                            android:enabled="false"
                            tools:text="Jyotirmoy Patra" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:text="@string/personal_information"
                android:textColor="@color/search_primary_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/search_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/ph"
                        style="@style/ModernDetailRow">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/phone_number" />

                        <EditText
                            android:id="@+id/viewPhoneNo"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            android:inputType="phone"
                            tools:text="9876543210" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/addrs"
                        style="@style/ModernDetailRow.Spaced">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/address" />

                        <EditText
                            android:id="@+id/viewAddress"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            android:inputType="textPostalAddress"
                            android:maxLines="3"
                            android:singleLine="false"
                            tools:text="Daspur, Ghatal, 721211" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/dob"
                        style="@style/ModernDetailRow.Spaced">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/date_of_birth" />

                        <EditText
                            android:id="@+id/viewDob"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            tools:text="12/08/1990" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:text="@string/policy_information"
                android:textColor="@color/search_primary_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/search_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/policyNumber"
                        style="@style/ModernDetailRow">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/policy_number" />

                        <EditText
                            android:id="@+id/viewPolicyNo"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            tools:text="123456789" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/premium"
                        style="@style/ModernDetailRow.Spaced">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/premium_label" />

                        <EditText
                            android:id="@+id/viewPremium"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            android:inputType="numberDecimal"
                            tools:text="₹ 2,500" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/policyTermTable"
                        style="@style/ModernDetailRow.Spaced">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/policy_table_term_label" />

                        <EditText
                            android:id="@+id/viewPolicyTable"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            tools:text="Table 914 / 20 years" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/SumAssured"
                        style="@style/ModernDetailRow.Spaced">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/sum_assured_label" />

                        <EditText
                            android:id="@+id/viewSumAssured"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            android:inputType="numberDecimal"
                            tools:text="₹ 5,00,000" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:text="@string/important_dates"
                android:textColor="@color/search_primary_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/search_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/doc"
                        style="@style/ModernDetailRow">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/date_of_commencement" />

                        <EditText
                            android:id="@+id/viewDoc"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            tools:text="01/01/2024" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/dom"
                        style="@style/ModernDetailRow.Spaced">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/date_of_maturity_label" />

                        <EditText
                            android:id="@+id/viewDom"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            tools:text="01/01/2044" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/dLp"
                        style="@style/ModernDetailRow.Spaced">

                        <TextView
                            style="@style/ModernDetailLabel"
                            android:text="@string/date_of_last_payment_label" />

                        <EditText
                            android:id="@+id/viewDLP"
                            style="@style/ModernDetailValue"
                            android:enabled="false"
                            tools:text="01/01/2043" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
