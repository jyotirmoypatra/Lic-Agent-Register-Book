<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/search_screen_background"
    tools:context=".AddNewDetailsActivity">

    <View
        android:id="@+id/addDetailsHeader"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:background="@drawable/search_header_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/addDetailsBackButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:padding="9dp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/addDetailsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="20dp"
        android:text="@string/add_policy_holder"
        android:textColor="@color/white"
        android:textSize="21sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/addDetailsBackButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/addDetailsBackButton"
        app:layout_constraintTop_toTopOf="@id/addDetailsBackButton" />

    <TextView
        android:id="@+id/addDetailsSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="24dp"
        android:text="@string/add_details_subtitle"
        android:textColor="@color/search_header_subtitle"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/addDetailsBackButton" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/addDetailsHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="10dp"
                android:text="@string/personal_information"
                android:textColor="@color/search_primary_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/search_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/name"
                        style="@style/ModernFormField">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_account" />

                        <EditText
                            android:id="@+id/enterName"
                            style="@style/ModernFormEditText"
                            android:hint="@string/enter_name"
                            android:inputType="textCapWords" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/phoneNo"
                        style="@style/ModernFormField.Spaced">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_phone" />

                        <EditText
                            android:id="@+id/enterPhoneNo"
                            style="@style/ModernFormEditText"
                            android:hint="@string/enter_phone_number"
                            android:inputType="phone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/address"
                        style="@style/ModernFormField.Spaced">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_location" />

                        <EditText
                            android:id="@+id/enterAddress"
                            style="@style/ModernFormEditText"
                            android:hint="@string/enter_address"
                            android:inputType="textPostalAddress"
                            android:maxLines="2" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/Dob"
                        style="@style/ModernFormField.Spaced">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_calendar" />

                        <EditText
                            android:id="@+id/enterDob"
                            style="@style/ModernFormEditText"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:hint="@string/date_of_birth" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:text="@string/policy_information"
                android:textColor="@color/search_primary_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/search_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/policyNo"
                        style="@style/ModernFormField">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_policy_icon" />

                        <EditText
                            android:id="@+id/enterPolicyNo"
                            style="@style/ModernFormEditText"
                            android:hint="@string/enter_policy_number"
                            android:inputType="text" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/Premium"
                        style="@style/ModernFormField.Spaced">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@mipmap/rupees" />

                        <EditText
                            android:id="@+id/enterPremium"
                            style="@style/ModernFormEditText"
                            android:hint="@string/premium"
                            android:inputType="numberDecimal" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/policyTable"
                        style="@style/ModernFormField.Spaced">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_table" />

                        <EditText
                            android:id="@+id/enterPolicyTable"
                            style="@style/ModernFormEditText"
                            android:hint="@string/policy_table_and_term"
                            android:inputType="text" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/sumAssured"
                        style="@style/ModernFormField.Spaced">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@mipmap/rupees" />

                        <EditText
                            android:id="@+id/enterSumAssured"
                            style="@style/ModernFormEditText"
                            android:hint="@string/sum_assured"
                            android:inputType="numberDecimal" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:text="@string/important_dates"
                android:textColor="@color/search_primary_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/search_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/Doc"
                        style="@style/ModernFormField">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_calendar" />

                        <EditText
                            android:id="@+id/enterDoc"
                            style="@style/ModernFormEditText"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:hint="@string/date_of_commencement" />

                        <ImageView
                            android:id="@+id/clearDoc"
                            style="@style/ModernClearIcon"
                            android:contentDescription="@string/clear_date"
                            android:src="@mipmap/cross"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/dateMaturity"
                        style="@style/ModernFormField.Spaced">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_calendar" />

                        <EditText
                            android:id="@+id/enterDateMaturity"
                            style="@style/ModernFormEditText"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:hint="@string/date_of_maturity" />

                        <ImageView
                            android:id="@+id/clearMaturity"
                            style="@style/ModernClearIcon"
                            android:contentDescription="@string/clear_date"
                            android:src="@mipmap/cross"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/lastPayment"
                        style="@style/ModernFormField.Spaced">

                        <ImageView
                            style="@style/ModernFormIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_calendar" />

                        <EditText
                            android:id="@+id/enterLastPayment"
                            style="@style/ModernFormEditText"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:hint="@string/date_of_last_payment" />

                        <ImageView
                            android:id="@+id/clearLastPaymentDate"
                            style="@style/ModernClearIcon"
                            android:contentDescription="@string/clear_date"
                            android:src="@mipmap/cross"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/modern_primary_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/save_policy_holder"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
